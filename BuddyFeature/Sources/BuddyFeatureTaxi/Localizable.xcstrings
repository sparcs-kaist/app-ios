    },
    "You can launch the taxi app with the departure and destination already set. Once everyone has gathered at the departure point, press the button to call a taxi from %@ to %@." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can launch the taxi app with the departure and destination already set. Once everyone has gathered at the departure point, press the button to call a taxi from %1$@ to %2$@."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "You can launch the taxi app with the departure and destination already set. Once everyone has gathered at the departure point, press the button to call a taxi from %1$@ to %2$@."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "출발지와 도착지가 이미 설정된 상태로 택시 호출 앱을 실행할 수 있습니다. 동승 인원과 출발지에서 모였다면, 버튼을 눌러 %1$@에서 %2$@로 가는 택시를 호출하세요."
          }
        }
      }
