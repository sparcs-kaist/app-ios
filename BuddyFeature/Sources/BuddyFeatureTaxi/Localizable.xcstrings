    "There are rooms for which settlement has not been completed. To create a room, please settle an existing room." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "There are rooms for which settlement has not been completed. To create a room, please settle an existing room."
          }
